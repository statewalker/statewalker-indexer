{
  "name": "@statewalker/indexer-tests",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shared test suite for @statewalker/indexer-* implementations. Internal dev-only; not published.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/statewalker/statewalker-indexer.git"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "lint": "biome check --write .",
    "format": "biome format --write ."
  },
  "dependencies": {
    "@statewalker/indexer-api": "workspace:*"
  },
  "peerDependencies": {
    "vitest": "*"
  },
  "devDependencies": {
    "rimraf": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
